{
  "name": "json2any",
  "version": "2.0.1",
  "description": "Fast JSON to CSV converter — Excel-safe, streaming, two-pass GB-scale support. ESM + CJS + TypeScript.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "types": "./dist/types/index.d.ts"
    }
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node build.mjs",
    "test": "echo \"No tests yet\""
  },
  "keywords": [
    "json",
    "csv",
    "json to csv",
    "json converter",
    "csv export",
    "excel csv",
    "json stream",
    "ndjson",
    "data conversion",
    "streaming",
    "two-pass",
    "large files",
    "typescript"
  ],
  "author": "Chandru Ganesh",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}

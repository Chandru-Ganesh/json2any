{
  "name": "json2any",
  "version": "2.0.2",
  "description": "Fast JSON to CSV converter — Excel-safe, streaming, two-pass GB-scale support. ESM + CJS + TypeScript.",
  "type": "module",
  "exports": {
    ".": {
      "types":   "./dist/types/index.d.ts",
      "import":  "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "main":   "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types":  "./dist/types/index.d.ts",
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node build.mjs",
    "test":  "echo \"No tests yet\""
  },
  "keywords": [
    "json",
    "json2any",
    "2",
    "any",
    "csv",
    "json to csv",
    "json converter",
    "csv export",
    "excel csv",
    "json stream",
    "ndjson",
    "data conversion",
    "streaming",
    "two-pass",
    "large files",
    "typescript"
  ],
  "engines": {
    "node": ">=16"
  },
  "sideEffects": false,
  "author": "Chandru Ganesh",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}